# ------------------------------
# Application identity
# ------------------------------
APP_NAME=demo-fullstack-app
APP_ENV=development
APP_REGION=us-east-1
APP_TIMEZONE=UTC

# ------------------------------
# Frontend runtime flags
# ------------------------------
VITE_APP_TITLE=Demo Fullstack Platform
VITE_API___BASE_URL=http://localhost:4000
VITE_ENABLE_MOCKS=false
# VITE_ENABLE_MOCKS=true
VITE_FEATURE_BETA_DASHBOARD=true
VITE_RELEASE_CHANNEL=canary

# JSON-like env values for parsing tests
VITE_ALLOWED_LOCALES=["en","fr","de"]
VITE_DEFAULT_FILTERS={"sort":"name","order":"asc","limit":25}

# ------------------------------
# Backend server
# ------------------------------
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=debug
REQUEST_TIMEOUT_MS=10000
TRUST_PROXY=false

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# Security middleware knobs
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
HELMET_ENABLED=true
BODY_LIMIT=2mb

# ------------------------------
# Database and cache
# ------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/demoapp
REDIS_URL=redis://localhost:6379/0
DB_POOL_MIN=2
DB_POOL_MAX=12

# ------------------------------
# Auth and tokens
# ------------------------------
JWT_ISSUER=demo-auth
JWT_AUDIENCE=demo-clients
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_SECRET=replace-this-in-real-env

# Multi-line-like value (escaped newline)
PRIVATE_KEY=-----BEGIN KEY-----\nabc123\ndef456\n-----END KEY-----

# ------------------------------
# Optional integrations
# ------------------------------
SENTRY_DSN=
OPEN_TELEMETRY_ENDPOINT=
ENABLE_SWAGGER=true
ENABLE_REQUEST_LOG_BODY=false

# Comment/uncomment playground
# FEATURE_FLAG_ADVANCED_SEARCH=false
FEATURE_FLAG_ADVANCED_SEARCH=true
# FEATURE_FLAG_SERVER_SIDE_EXPORTS=true

# OpenRewrite to Comby testing vars
# Server Configuration
APP_PORT=8080
NODE_ENV=production
# Database "Nested" Elements
DB_USER=admin
DB_HOST=localhost
DB_PORT=5432 

# Feature Toggles
# DEBUG_MODE=true # This line should be commented
TEMP_LOGGING=enabled
