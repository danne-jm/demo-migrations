engine marzano(0.1)
language js

pattern env_mods() {
  // Match env-style keys like DB_USER, API_TOKEN, etc.
  // Only keys with a single underscore and an all-caps/digit suffix are rewritten,
  // mirroring the original Comby smart_auto_nest rule.
  identifier() as $id where {
    $id <: r"^(DB|API|AWS|S3|MAIL)_([A-Z0-9]+)$" ($prefix, $key),
    $new_id = join([$prefix, "__", $key], "")
  } => $new_id
}

env_mods()
