    "koa": "^3.0.0",
    "koa-bodyparser": "^4.4.1",
    "koa-compress": "^5.1.1",
    "koa-helmet": "^9.0.0",
    "rate-limiter-flexible": "^10.0.0"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^3.3.1",
    "@types/koa__router": "^12.0.4",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/node": "^22.14.1",
    "eslint": "^9.23.0",
    "ts-node-dev": "^2.0.0",
