    "dotenv": "^16.5.0",
    "koa": "^2.16.2",
    "koa-bodyparser": "^4.4.1",
    "koa-compress": "^5.1.1",
    "koa-helmet": "^8.0.1",
    "rate-limiter-flexible": "^5.0.4",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/koa": "^3.0.0",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/node": "^24.0.0",
    "eslint": "^10.0.0",
